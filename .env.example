# LINE Developers Console → Messaging API (optional ถ้าใช้ Telegram Mini App เป็นหลักและไม่ใช้ LINE OA)
# LINE_CHANNEL_SECRET=your_channel_secret
# LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_channel_access_token

# --- แจ้งเตือนอัตโนมัติ (cron) ลำดับ: Telegram → Discord webhook → LINE push (เฉพาะเมื่อเปิดด้านล่าง) ---
# LINE push สำหรับ alert — ค่าเริ่มปิด (เน้น Telegram); ตั้ง =1 เพื่อใช้ LINE เป็นช่องหลักหรือ mirror
# LINE_ALERT_PUSH_ENABLED=1
# Telegram (แนะนำ): สร้างบอทที่ @BotFather แล้วกด Start ที่บอท — หรือพิมพ์ /chatid ในแชท (webhook ตอบ chat_id + topic โดยไม่ต้อง deleteWebhook)
# TELEGRAM_BOT_TOKEN=123456:ABC...
# Admin (ใช้ร่วม LINE + Telegram):
# - ใส่ LINE user id (ขึ้นต้น U...) และ/หรือ Telegram user id (ตัวเลข) คั่นด้วย comma
#   ตัวอย่าง: KOJI_ADMIN_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,123456789
# (ยังรองรับ env เก่า TELEGRAM_CRON_RUN_ALLOWED_USER_IDS / SPARK_MATRIX_RESET_ALLOWED_USER_IDS)
# KOJI_ADMIN_IDS=
# อนุญาต “รัน cron จากแชท Telegram” (ตัวเลข user id คั่นด้วย comma) — ป้องกันคนอื่นสั่งยิงหนัก ๆ
# ดู user id: forward ข้อความถึง @userinfobot หรือใช้ log ใน server (from id)
# TELEGRAM_CRON_RUN_ALLOWED_USER_IDS=123456789,987654321
# ปิดคำสั่ง /chatid ใน webhook — ค่าเริ่มเปิด
# TELEGRAM_WEBHOOK_CHATID_CMD_ENABLED=0
# TELEGRAM_ALERT_CHAT_ID=123456789
# แยกห้องรับ system error logs (cron fail ฯลฯ) ออกจาก TELEGRAM_ALERT_CHAT_ID — ไม่ตั้ง = ใช้ TELEGRAM_ALERT_CHAT_ID เหมือนเดิม
# TELEGRAM_SYSTEM_ERROR_CHAT_ID=123456789
# ถ้าเป็นกลุ่มแบบ Forum: ใส่ topic id (message_thread_id)
# TELEGRAM_SYSTEM_ERROR_MESSAGE_THREAD_ID=12345
# --- Telegram Mini App — หน้าเว็บเรียก /api/tma/* ด้วย Authorization: tma <initData> (ยืนยันด้วย TELEGRAM_BOT_TOKEN)
# URL ฝั่งเว็บสำหรับปุ่ม Web App / webhook / BotFather Menu Button (เช่น https://your-app.vercel.app/)
# TELEGRAM_MINI_APP_URL=https://your-app.vercel.app
# Webhook: POST /api/telegram/webhook — ตั้งด้วย Bot API setWebhook (BotFather ไม่ตั้ง URL webhook ให้)
# อายุ initData สูงสุด (วินาที) — ค่าเริ่ม 86400
# TELEGRAM_TMA_AUTH_MAX_AGE_SEC=86400
# Spark follow-up + System Change + public indicator feed → กลุ่ม Telegram (ส่งครั้งเดียวต่อข้อความ; ไม่ใช้ TELEGRAM_ALERT_CHAT_ID เมื่อตั้งค่านี้)
# เพิ่มบอทเข้ากลุ่ม แล้วดึง chat_id จาก getUpdates (มักขึ้นต้น -100...) — ลิงก์ t.me/c/... ไม่ใช่ chat_id สำหรับ API
# TELEGRAM_PUBLIC_CHAT_ID=-1001234567890
# legacy: ถ้ายังไม่มี TELEGRAM_PUBLIC_CHAT_ID จะใช้ chat นี้แทน (ไม่แนะนำ — ตั้งกลุ่มหลักด้านบนให้ครบ)
# TELEGRAM_MARKET_PULSE_CHAT_ID=-1009876543210
# กลุ่มแบบ Forum (มี Topics): ใส่เลข topic จาก message_thread_id ในข้อความที่ส่งใน topic นั้น
# TELEGRAM_PUBLIC_MESSAGE_THREAD_ID=12345
# แยกหัวข้อตามชนิดสัญญาณ (กลุ่มเดียวกับ TELEGRAM_PUBLIC_CHAT_ID) — ถ้าไม่ตั้งค่าใดค่าหนึ่งด้านล่าง จะ fallback ไป TELEGRAM_PUBLIC_MESSAGE_THREAD_ID แล้วจึง General
# Spark / high momentum: PRICE_SPIKE_15M + Spark follow-up
# TELEGRAM_PUBLIC_SPARK_MESSAGE_THREAD_ID=11111
# Condition / macro: spot–perp basis + MEXC funding/order limits (ไม่รวม Market Pulse — แยก topic ด้านล่าง)
# TELEGRAM_PUBLIC_CONDITION_MESSAGE_THREAD_ID=22222
# Market Pulse (F&G cron) — topic แยกในกลุ่มเดียวกับ TELEGRAM_PUBLIC_CHAT_ID · ไม่ตั้ง → fallback topic condition แล้วจึง TELEGRAM_PUBLIC_MESSAGE_THREAD_ID
# TELEGRAM_PUBLIC_MARKET_PULSE_MESSAGE_THREAD_ID=22223
# Technical / execution: public Binance RSI·EMA feed + mirror indicator alerts + volume signal
# TELEGRAM_PUBLIC_TECHNICAL_MESSAGE_THREAD_ID=33333
# Snowball Triple-Check (15m) — topic แยกในกลุ่มเดียวกัน · ไม่ตั้ง → fallback TELEGRAM_PUBLIC_TECHNICAL_MESSAGE_THREAD_ID แล้วจึง TELEGRAM_PUBLIC_MESSAGE_THREAD_ID
# TELEGRAM_PUBLIC_SNOWBALL_MESSAGE_THREAD_ID=33334
# Reversal 1D (โดจิกลับหัว / แท่งแดงทุบ) — topic แยก · ไม่ตั้ง → fallback TELEGRAM_PUBLIC_TECHNICAL_MESSAGE_THREAD_ID
# TELEGRAM_PUBLIC_REVERSAL_MESSAGE_THREAD_ID=33335
# Upcoming events (กลุ่มเดียวกับ TELEGRAM_PUBLIC_CHAT_ID) — Weekly digest / Pre-event VIP — ผลจริงใช้ events_result หรือ fallback ไป condition topic
# Weekly digest: ไม่ตั้ง weekly → ลอง session → pre → result → condition → TELEGRAM_PUBLIC_MESSAGE_THREAD_ID
# TELEGRAM_PUBLIC_EVENTS_WEEKLY_MESSAGE_THREAD_ID=44441
# TELEGRAM_PUBLIC_EVENTS_PRE_MESSAGE_THREAD_ID=44442
# TELEGRAM_PUBLIC_EVENTS_RESULT_MESSAGE_THREAD_ID=44443
# US session (เปิด/ปิด Wall St. ตามเวลาไทย) — หรือ fallback ไป weekly topic
# TELEGRAM_PUBLIC_EVENTS_SESSION_MESSAGE_THREAD_ID=44444
# TELEGRAM_SPARK_SYSTEM_CHAT_ID=-1001234567890
# (legacy — ใช้เมื่อยังไม่ตั้ง TELEGRAM_PUBLIC_CHAT_ID)
# ส่งซ้ำไป LINE ด้วย: ALERT_ALSO_LINE_PUSH=1 และ LINE_ALERT_PUSH_ENABLED=1
# ALERT_ALSO_LINE_PUSH=1

# Discord (ถ้าไม่ใช้ Telegram): Webhooks — อย่า commit URL จริง; ถ้ารั่วให้ลบ webhook แล้วสร้างใหม่
# DISCORD_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
# DISCORD_ALERT_MENTION_USER_IDS=123456789012345678
# DISCORD_ALERT_ALSO_LINE_PUSH=1

# เว้นระหว่างการเรียก LINE push (มิลลิวินาที) — ใช้เมื่อไม่มี Telegram/Discord (ค่าเริ่ม 280)
# LINE_PUSH_MIN_INTERVAL_MS=280

# Legacy LINE OA + LIFF (ยังเรียก /api/liff ได้เมื่อใส่ env) — โหมดหลักสำหรับแอปเว็บคือ Telegram Mini App (/api/tma)
# LINE_CHANNEL_ID=1234567890
# LIFF_ID=1234567890-abcdefgh

# optional (local file เมื่อไม่มี REDIS_URL / KV)
# โฟลเดอร์ data/: alerts.json, pct_step_alerts.json, volume_signal_alerts.json, indicator_alerts.json, indicator_public_feed_state.json, upcoming_events_state.json, upcoming_events_snapshot.json, contract_watches.json, contract_snap_*.json, funding_history_24h.json, system_change_subscribers.json, spot_fut_basis_alert_state.json, price_spike_15m_alert_state.json, spark_autotrade_state.json, ema612_15m_watch_cross_state.json, market_pulse_volume_snapshots.json, market_pulse_alert_state.json, trading_view_mexc_settings.json, trading_view_open_wizard.json, tv_webhook_used_nonces.json, cron_status.json (legacy), cron_status_hourly.json, cron_status_price_sync.json

# TradingView Webhook → ปิด position บน MEXC (USDT ฟิวเจอร์) — ค่าเริ่ม `https://api.mexc.com` ตรง [MEXC Futures API]
# MEXC_FUTURES_API_BASE_URL=https://api.mexc.com
# MEXC_FUTURES_RECV_WINDOW=60
# เมื่อ POST /api/webhooks/tv (หรือ legacy /api/webhooks/tv/close) body ไม่ใช่ JSON ที่อ่านได้ — แจ้งเฉพาะ admin (ไม่ DM user จาก body ดิบ)
# TELEGRAM_TV_WEBHOOK_MALFORMED_CHAT_ID=-1001234567890
# (ถ้าไม่ตั้ง → ใช้ TELEGRAM_ALERT_CHAT_ID) · Forum topic ถ้ามี:
# TELEGRAM_TV_WEBHOOK_MALFORMED_MESSAGE_THREAD_ID=12345

# Market Pulse — F&G + BTC.D + Vol (cron /api/cron/market-pulse ทุกชั่วโมง UTC — ผู้รับเดียวกับ «ติดตามระบบ»)
# ค่าเริ่มเปิด — ปิดเท่านั้นที่ตั้ง MARKET_PULSE_ENABLED=0
# MARKET_PULSE_ENABLED=0
# ส่งเมื่อ |Δ Fear & Greed| ≥ เกณฑ์ — ค่าเริ่ม 3
# MARKET_PULSE_ALERT_DELTA_FNG=3
# อย่างน้อยหนึ่งครั้งต่อช่วงหลัง push สำเร็จล่าสุด (ดีฟอลต์ ~24 ชม.) แม้ ΔF&G ยังไม่ถึงเกณฑ์ — ปิด: MARKET_PULSE_DAILY_MIN=0
# MARKET_PULSE_DAILY_MIN_SEC=86400
# ส่งทุกรอบ cron (รายชั่วโมง) แม้ ΔF&G เล็ก — ไม่ต้องใช้ถ้าเปิด daily min แล้วพอ
# MARKET_PULSE_ALWAYS_NOTIFY=1
# ใช้ CoinMarketCap Pro (ดัชนี F&G + ตลาดตรงกับการ์ดบน CMC) — สมัครที่ https://pro.coinmarketcap.com/signup
# ถ้าไม่ตั้ง: ใช้ Alternative.me + CoinGecko (ตัวเลข F&G จะไม่ตรงกับ CMC)
# CMC_PRO_API_KEY=your_cmc_pro_api_key

# --- AI (Gemini) ---
# ใช้สำหรับสรุปข้อความบางคำสั่ง (เช่น portfolio status AI Summary)
# GEMINI_API_KEY=
# รุ่นโมเดล (ค่าเริ่ม gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash
# timeout (ms) สำหรับเรียก Gemini (3000–60000; default 12000)
# GEMINI_TIMEOUT_MS=12000
# เปิด/ปิด AI Summary ใน portfolio status (ค่าเริ่มเปิด; ปิด: 0/false/off)
# PORTFOLIO_AI_SUMMARY_ENABLED=1

# --- AI (OpenRouter) ---
# แนะนำให้ใช้ OpenRouter เป็น provider สำหรับ AI Summary ใน portfolio status (เสถียร/เลือกโมเดลได้)
# OPENROUTER_API_KEY=
# โมเดลค่าเริ่ม: google/gemini-3.1-pro-preview (เปลี่ยนได้ตามชอบ)
# OPENROUTER_MODEL=google/gemini-3.1-pro-preview
# timeout (ms) สำหรับเรียก OpenRouter (3000–90000; default 25000)
# OPENROUTER_TIMEOUT_MS=25000
# debug: ส่ง curl template + raw response (truncated) เมื่อ AI Summary fail
# PORTFOLIO_AI_DEBUG=1
# debug: ใส่ข้อความพอร์ตเต็ม ๆ ลงใน curl body (ปกติจะ redacted ให้สั้น)
# PORTFOLIO_AI_DEBUG_CURL=1

# --- AI (OpenAI) ---
# ใช้สำหรับ AI Summary ใน portfolio status (แนะนำ)
# OPENAI_API_KEY=
# ค่าเริ่ม: gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
# timeout (ms) สำหรับเรียก OpenAI (3000–90000; default 20000)
# OPENAI_TIMEOUT_MS=20000

# Spot–perp basis / ราคาผิดปกติ (cron /api/cron/price-sync ทุก ~15 นาที) — ส่ง Telegram กลุ่มสาธารณะเมื่อตั้ง TELEGRAM_PUBLIC_* + ยังส่งต่อ subscriber ระบบ (ถ้ามี)
# |basis| ≤ WARNING_MIN = ไม่แจ้ง — ค่าต่ำสุด 2% (ตั้งต่ำกว่า 2 จะถูกยกเป็น 2)
# SPOT_FUT_BASIS_WARNING_MIN=2.0
# SPOT_FUT_BASIS_EXTREME_MIN=3.0
# SPOT_FUT_BASIS_RENOTIFY_DELTA=1
# จำกัดการแจ้งเตือน "Price Gap Detected" ต่อเหรียญต่อวัน (เวลาไทย) — default 3 (ตั้ง 0 = ไม่จำกัด)
# SPOT_FUT_BASIS_DAILY_MAX_PER_SYMBOL=3

# Koji Spark: |% เปลี่ยน| ของราคา last (ticker) เทียบจุดอ้างอิง — ไม่อิงแท่งเทียน — cron /api/cron/pct-trailing ~5 นาที — ผู้รับเดียวกับ «ติดตามระบบ»
# PRICE_SPIKE_15M_ENABLED=1
# หลังส่ง Spark แล้ว ไม่ส่งซ้ำต่อสัญญาเดียวกันภายในช่วงนี้ (วินาที) — default 86400 (24 ชม.) · ตั้ง 0 = ปิด cooldown · แบบถี่: 900 (15 นาที)
# SPARK_ALERT_COOLDOWN_SEC=86400
# ยืนยันด้วย MEXC kline ก่อนส่ง Spark (แท่งปิดติดกัน + vol เทียบ baseline) — ค่าเริ่มปิด
# SPARK_KLINE_CONFIRM_ENABLED=1
# Min15 (ค่าเริ่ม) | Min60 | Hour4
# SPARK_KLINE_CONFIRM_INTERVAL=Min15
# จำนวนแท่งปิดติดกันที่ต้องเป็นสีเดียวกับทิศสัญญาณ (1–5, default 2)
# SPARK_KLINE_CONFIRM_BARS=2
# ความยาว baseline สำหรับ median volume ก่อนแท่งแรกของสตรีค (3–80, default 20)
# SPARK_KLINE_CONFIRM_BASELINE_BARS=20
# แต่ละแท่งในสตรีค vol ต้อง >= ratio * median(baseline) (default 1)
# SPARK_KLINE_CONFIRM_MIN_VOL_RATIO=1
# ดึง kline ไม่ได้: ไม่ส่ง (default) — ตั้ง 1 = ยังส่งเหมือนเดิม (fail-open)
# SPARK_KLINE_CONFIRM_FAIL_OPEN=0
# SPARK_KLINE_CONFIRM_DEBUG=1
# กรองสัญญาที่ amount24 (USDT) ต้องมากกว่านี้ก่อนเข้า universe ของ Spark (default 1,000,000)
# ลดลงเพื่อให้เหรียญกลาง/เล็กถูก sample ต่อเนื่องขึ้น (แลกกับ universe กว้างขึ้น + เสี่ยง rate limit มากขึ้น)
# SPARK_MIN_AMOUNT24_USDT=1000000
# ขาขึ้น / ขาลง คนละเกณฑ์ — ถ้าไม่ตั้ง PRICE_SPIKE_MIN_PCT_* จะใช้ PRICE_SPIKE_15M_MIN_PCT แทนขาขึ้นอย่างเดียว (เลขเก่า) — ดีฟอลต์โค้ดขาขึ้น/ลง 5%
# PRICE_SPIKE_MIN_PCT_UP=9
# PRICE_SPIKE_MIN_PCT_DOWN=9
# PRICE_SPIKE_15M_MIN_PCT=10
# PRICE_SPIKE_15M_TOP_N=100
# ช่วงเวลาเทียบราคา (วินาที) — คั่นด้วย comma (default: 300,600,900 = 5m/10m/15m)
# SPARK_SIGNAL_WINDOWS_SEC=300,600,900
# legacy (ตั้งเดี่ยวช่วงเดียว): SPARK_SIGNAL_WINDOW_SEC=900
# เก็บราคา last ย้อนหลังเพื่อ debug Spark (วินาที) — default 3600 = 1 ชม. (ช่วงที่รับได้ 900–86400)
# SPARK_PRICE_HISTORY_KEEP_SEC=3600

# Spark auto-open — หลังแจ้งเตือน Spark **ส่งสำเร็จ** ใน cron pct-trailing: ให้เรียก MEXC เปิดโพซิชันตามทิศสัญญาณให้ผู้ใช้ที่เปิดจาก Mini App (+ MEXC key) และตั้งใน Settings
# ความเสี่ยงสูง — เปิดเมื่อเข้าใจแล้ว · อย่างมากเปิดจาก Spark ได้ **1 ครั้งสำเร็จต่อเหรียญต่อผู้ใช้ต่อวันปฏิทินไทย** (เก็บ state ใน KV/Redis หรือ spark_autotrade_state.json เวลาทำงาน local)
# ต้อง REDIS/KV พร้อมอยู่เหมือน trading_view_mexc_settings และตั้ง MEXC API จาก Mini App เหมือน TradingView webhook
# SPARK_AUTOTRADE_ENABLED=0
# Time-stop ปิด position หลัง Spark เปิด: ตั้งใน Mini App (เช่น ~3 ชม.) — คิวเก็บใน spark_autotrade_state แล้วสแกนทุกรอบ cron ticker เดียวกับด้านบน (~5 นาที ไม่เที่ยงวินาที)
# ฟิลเตอร์สัญญาณ Spike (ขึ้น/ลง) + ฝั่งออเดอร์ (follow / fade / long / short) ตั้งได้ใน Telegram Mini App → Spark auto-open (`orderSide`) ไม่ใช้ env

# Snowball auto-open — หลัง Snowball ส่งสัญญาณ **closed bar** สำเร็จ: ให้เรียก MEXC เปิดโพซิชันตามทิศสัญญาณให้ผู้ใช้ที่เปิดจาก Mini App (+ MEXC key) และตั้งใน Settings
# ความเสี่ยงสูง — เปิดเมื่อเข้าใจแล้ว · อย่างมากเปิดจาก Snowball ได้ **1 ครั้งสำเร็จต่อเหรียญต่อผู้ใช้ต่อวันปฏิทินไทย** (เก็บ state ใน KV/Redis หรือ snowball_autotrade_state.json)
# Features:
# - Quick TP: ถ้า ROI แตะเป้าใน N ชม. → ปิด market (ตามรอบ cron)
# - 24h rule: ถ้าครบ 24 ชม. แล้วยังต่ำกว่าจุดซื้อและไม่เข้าเกณฑ์รันเทรน → ปิด market
# Kill switch ฝั่งเซิร์ฟ (ค่าเริ่มต้น = เปิดเมื่อไม่ตั้งค่า): ตั้งเป็น 0 / false / off / no เพื่อปิดการสั่งเปิดทั้งระบบ
# SNOWBALL_AUTOTRADE_ENABLED=0
# Auto-open จากสัญญาณ LONG + Double Barrier: Grade A+ → Long · Grade B = ไม่สั่ง
# Grade C (ต่ำกว่า B) → Short (fade) เมื่อผ่าน gate 1h ในกรอบ 4h: close ล่าสุด < EMA และ (rejection ≥2 ไส้บน>% หรือ V-Top: แท่งก่อนเขียว+แท่งล่าสุดแดงทุบ≥ratio×เนื้อเขียว)
# SNOWBALL_GRADE_C_SHORT_MIN_1H_REJECTIONS=2
# SNOWBALL_GRADE_C_SHORT_UPPER_WICK_PCT=50
# SNOWBALL_GRADE_C_SHORT_EMA_PERIOD=20
# SNOWBALL_GRADE_C_SHORT_VTOP_ENGULF_RATIO=0.5
# Entry: สายไส้ (rejection≥2) → Limit SHORT ที่ close+ไส้บน/2 · สาย V-Top → Market SHORT ทันที (ทริกเกอร์ ≤ closeก่อนหน้า−ratio×เนื้อเขียว)

# Spark follow-up: หลังแจ้ง Spark สำเร็จ — ติดตาม T+30m / T+1h … จากเวลาปิดแท่ง 5m (บันทึกสถิติใน state ครบทุกจุด; ไม่ส่งข้อความ checkpoint T+30m ไป Telegram/LINE)
# SPARK_FOLLOWUP_ENABLED=1
# ขณะมีรายการ pending ต่อสัญญา — รอบ Spark ticker จะข้ามสัญญานั้นทั้งแถว (ไม่คำนวณ spike / ไม่ดึง kline ยืนยัน) จนกว่า pending จะถูกลบออกจากคิว
# แจ้งเตือนเมื่อดึงราคา follow-up ไม่สำเร็จ (เฉพาะ Spark follow-up tick) — เฉพาะคู่ที่ map ไป Binance ได้และลอง MEXC+Binance แล้วยังไม่มีราคา — ปิด: 0 / false / off
# SPARK_FOLLOWUP_PRICE_FAIL_NOTIFY=1
# ไม่แจ้ง Telegram เมื่อดึงราคา follow-up ล้มเหลวแบบชั่วคราว (MEXC 510/429, Binance 451 geo) — ค่าเริ่มเปิด — ปิด: SPARK_FOLLOWUP_PRICE_FAIL_SUPPRESS_TRANSIENT=0
# SPARK_FOLLOWUP_PRICE_FAIL_SUPPRESS_TRANSIENT=1
# SPARK_FOLLOWUP_HISTORY_MAX=400
# จำนวน log รายการ Spark ที่แจ้งแล้ว (สำหรับคำสั่งสถิติ)
# SPARK_FIRE_LOG_MAX=300
# ล้างข้อมูล Spark matrix / follow-up state เก่า (เรียกครั้งเดียวเมื่อต้องการเริ่มเก็บสถิติใหม่):
#   curl -sS -H "Authorization: Bearer $CRON_SECRET" "https://<โฮสต์>/api/cron/reset-spark-state"
# (ล้าง pending + history + recentSparks ใน KV/ไฟล์ spark_follow_up_state — ไม่ลบ price_spike state)
# หรือจากแชท LINE: พิมพ์ ล้างสถิติ spark / reset spark matrix / #sparkreset — ต้องใส่ LINE user id ใน env นี้ก่อน
# SPARK_MATRIX_RESET_ALLOWED_USER_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# เกณฑ์แบ่ง Vol 24h (amount24 USDT) — high ≥ ค่านี้, mid ≥ ค่านี้, ต่ำกว่า = low
# SPARK_VOL_TIER_HIGH_USDT=150000000
# SPARK_VOL_TIER_MID_USDT=30000000
# รายชื่อฐานสินทรัพย์ tier2 (พร็อกซีมาร์ก. — คั่นด้วย comma)
# SPARK_MCAP_TIER2_BASES=BNB,SOL,XRP,ADA,DOGE,TRX,LINK,AVAX
PORT=3000

# ดึงราคา MEXC หลายคู่ต่อครั้ง: หน่วง ms ระหว่าง GET รายสัญญา (ลด 510 Too frequent) — 0 = ปิด · แนะนำ 80–200 บน cron ที่มีหลาย follow-up
# MEXC_TICKER_INTER_SYMBOL_DELAY_MS=120
# Binance เป็น fallback ราคา (fetchSimplePrices / Spark follow-up) — ปิดเมื่อโฮสต์โดน 451 geo: CRYPTO_BINANCE_PRICE_FALLBACK=0
# CRYPTO_BINANCE_PRICE_FALLBACK=1

# หน้า Markets / Top loser: ตัวเลข %24h จาก MEXC contract/ticker — ค่าเริ่มใช้ riseFallRates.r ตรง API
# ถ้าไม่ตรงกับเว็บ mexc (สลับ 24h timezone) ลอง 0, 1 หรือ 2 = riseFallRatesOfTimezone[ดัชนี]
# MEXC_24H_FUTURES_CHANGE_TZ_INDEX=0

# ราคาและแจ้งเตือนใช้ MEXC Futures (สัญญา *_USDT)
# ถ้าเคยใช้เวอร์ชัน CoinGecko: ลบ data/alerts.json แล้วตั้งเตือนใหม่

# --- Vercel / Next.js เท่านั้น (ไม่มี Express) ---
# Cron (vercel.json): /api/cron/pct-trailing ทุก ~5 นาที (เตือน% trailing + Spark ticker + Spark follow-up) · /api/cron/price-sync ทุก ~15 นาที (เป้าราคา + เตือน% รายวัน + volume/RSI + spot–perp basis) · /api/cron/market-pulse ทุกชั่วโมง UTC (Market Pulse; แจ้งเมื่อ ΔF&G ≥ เกณฑ์) · /api/cron/price-alerts ทุกชั่วโมง — ส่ง Authorization: Bearer CRON_SECRET
# อ่านบันทึกรอบล่าสุด (รวม Spark ticker): LINE พิมพ์ สถานะ cron / สถานะ spark / spark cron — API: GET /api/cron/status + Bearer CRON_SECRET
# Webhook: https://<vercel-domain>/webhook
# Mini App Telegram เรียก same-origin /api/tma/... (LINE เดิมใช้ /api/liff/...) — เว้น NEXT_PUBLIC_API_BASE_URL ว่างบน Vercel

# บน Vercel ต้องมีอย่างใดอย่างหนึ่ง: Redis (REDIS_URL) หรือ Vercel KV (KV_REST_API_URL)
# ถ้ามี REDIS_URL จะใช้ node-redis ก่อน (TCP เช่น rediss://default:xxx@xxx.upstash.io:6379)
# ถ้าไม่มี Redis แต่มี KV_REST_API_URL ระบบจะใช้ @vercel/kv เหมือนเดิม
# REDIS_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# หน้า /markets แสดงคอลัมน์ Score·Vol×·15m ตลอด (ไม่ต้องใส่ ?debug=1)
# MARKETS_DEBUG_COLUMNS=1

# เกณฑ์แจ้งเตือน funding: |Δrate|×100 ≥ ค่านี้ (หน่วย % pt เช่น 0.1 = 0.01% → 0.11% ถึงแจ้ง) — ค่าเริ่มในโค้ด 0.1
# System conditions (LINE): แจ้งเมื่อ funding rate ถึงเกณฑ์นี้ หรือรอบชำระ (ชม.) เปลี่ยน หรือ max order size เปลี่ยน — ไม่แจ้งเมื่อมีแค่เวลาตัดถัดไป (nextSettleTime) เปลี่ยน
# CONTRACT_FUNDING_MIN_DELTA_DISPLAY=0.1

# Indicator alerts: RSI 14 บน TF 1h/4h + EMA cross 1h/4h — รวมจำนวนต่อ user · ดึง kline แบบ unique (symbol,TF) ต่อรอบ (MEXC)
# เมื่อตั้ง TELEGRAM_PUBLIC_* — หลังแจ้งผู้ใช้สำเร็จจะ mirror ข้อความเดียวกันเข้า Telegram กลุ่มสาธารณะ (คนละชุดกับ public Binance feed ด้านล่าง)
# INDICATOR_ALERT_MAX_PER_USER=30
# INDICATOR_ALERT_COOLDOWN_MS=14400000

# Public technical indicator feed — Binance USDT-M (RSI cross / EMA cross ค่าเริ่ม 4h; divergence ตั้ง TFS แยก) → Telegram กลุ่มสาธารณะ (topic technical: TELEGRAM_PUBLIC_TECHNICAL_MESSAGE_THREAD_ID หรือ fallback TELEGRAM_PUBLIC_MESSAGE_THREAD_ID) · Snowball ส่ง topic TELEGRAM_PUBLIC_SNOWBALL_MESSAGE_THREAD_ID (fallback technical) · ไม่ใช้ LINE subscriber
# Admin debug ใน Telegram DM / LINE: debug public feed [SYMBOL] · #publicfeeddebug · debug reversal risk SYMBOL · #reversalriskdebug SYMBOL (ต้อง KOJI_ADMIN_IDS)
# Telegram admin — ลบสถิติ Snowball + ปลดล็อกยิงซ้ำต่อสัญญา: snowball stats remove BTC · remove snowball stats PIEVERSEUSDT · ลบสถิติ snowball RIVER · #snowballstatsremove SYMBOL
# รอบเดียวกับ cron /api/cron/price-sync (runIndicatorAlertTick) — ต้องมี TELEGRAM_BOT_TOKEN + chat id กลุ่มสาธารณะ ถึงจะส่ง
# ค่าเริ่มในโค้ด = เปิด — ปิดด้วย INDICATOR_PUBLIC_FEED_ENABLED=0
# INDICATOR_PUBLIC_FEED_ENABLED=1
# Binance FAPI (klines + ticker 24hr) สำหรับ public indicator feed — โฮสต์บางที่ได้ HTTP 451 geo (เช่น Vercel iad1) ให้ย้าย regions เป็น sin1 ใน vercel.json หรือปิด: BINANCE_INDICATOR_FAPI_ENABLED=0
# BINANCE_INDICATOR_FAPI_ENABLED=1
#
# Downside / reversal alerts — สแกนสัญญา Binance USDT-M ทั้งหมดจาก exchangeInfo (Alert เท่านั้น) · ส่งเข้า Forum topic **technical** เดียวกับ RSI/EMA/volume technical (`sendTechnicalPublicBroadcastMessage` → TELEGRAM_PUBLIC_TECHNICAL_MESSAGE_THREAD_ID หรือ fallback TELEGRAM_PUBLIC_MESSAGE_THREAD_ID) · รอบเดียวกับ price-sync เมื่อเปิด DOWNSIDE_REVERSAL_ALERTS_ENABLED
# 15m: หัวปัก (Snowball-style breakout หรือ high ใหม่ + ไส้บน ≥40%) · 1h: แท่งแดง body+vol เกินเฉลี่ย 20 แท่ง · Trend broken: ปิด 1h ต่ำกว่า EMA20 (ตัดลง) หรือต่ำกว่า low แท่งสัญญาณล่าสุด
# DOWNSIDE_REVERSAL_ALERTS_ENABLED=1
# DOWNSIDE_REVERSAL_TELEGRAM_MESSAGE_THREAD_ID=   # optional — บังคับ message_thread_id ห้อง technical (ตัวเลขจาก Forum topic)
# DOWNSIDE_REVERSAL_MAX_SYMBOLS=0          # 0 = ไม่จำกัด (ทุกสัญญา); จำกัดโหลด cron ได้ เช่น 250
# DOWNSIDE_REVERSAL_SCAN_CONCURRENCY=10   # ดึง klines พร้อมกันต่อรอบ
# DOWNSIDE_REVERSAL_MAX_ALERTS_PER_RUN=45 # กัน spam ต่อรอบ cron
# DOWNSIDE_REVERSAL_WEAK_WICK_MIN_RATIO=0.4
# ใช้เกณฑ์ Vol/Swing/VAH เดียวกับ Snowball public (INDICATOR_PUBLIC_SNOWBALL_*)
#
# Candle Reversal 1D — สแกนแท่ง Day ปิด (โดจิกลับหัว + แท่งแดงทุบ) → Telegram topic TELEGRAM_PUBLIC_REVERSAL_MESSAGE_THREAD_ID · หน้า /reversal-stats
# CANDLE_REVERSAL_1D_ALERTS_ENABLED=1
# CANDLE_REVERSAL_TOP_ALTS=120              # universe ต่อรอบ (quote vol); 0 = ทุกสัญญาเมื่อ CANDLE_REVERSAL_MAX_SYMBOLS=0
# CANDLE_REVERSAL_MAX_SYMBOLS=120           # 0 = ทุกสัญญา USDT-M (หนัก)
# CANDLE_REVERSAL_SCAN_CONCURRENCY=8
# CANDLE_REVERSAL_MAX_ALERTS_PER_RUN=30
# CANDLE_REVERSAL_WICK_MIN_RATIO=0.65       # ไส้บน ≥ 65% ของช่วงแท่ง
# CANDLE_REVERSAL_BODY_MAX_RATIO=0.15       # เนื้อ ≤ 15%
# CANDLE_REVERSAL_HIGHEST_TAIL_LOOKBACK=30  # High สูงสุดใน N วัน
# CANDLE_REVERSAL_MARUBOZU_BODY_LOOKBACK=48   # แท่งแดง: high สูงสุด + เนื้อแดงยาวสุดใน N แท่ง (ดีฟอลต์ 48)
# CANDLE_REVERSAL_MARUBOZU_AFTER_DOJI_DAYS=5
# Candle Reversal 1H — สแกนแท่ง 1H ปิด (โดจิกลับหัว high 200 แท่ง + แท่งแดงทุบยาว) · topic เดียวกับ 1D
# CANDLE_REVERSAL_1H_ALERTS_ENABLED=1          # ไม่ตั้ง = ตาม CANDLE_REVERSAL_1D_ALERTS_ENABLED
# CANDLE_REVERSAL_1H_WICK_MIN_RATIO=0.65
# CANDLE_REVERSAL_1H_BODY_MAX_RATIO=0.20
# CANDLE_REVERSAL_1H_HIGHEST_HIGH_LOOKBACK=200   # inverted doji: high สูงสุดใน N แท่ง 1H (ดีฟอลต์ 200)
# CANDLE_REVERSAL_1H_LONGEST_RED_LOOKBACK=24
# CANDLE_REVERSAL_1H_LONGEST_RED_MIN_RATIO=0.8
# CANDLE_REVERSAL_1H_LONGEST_RED_HIGH_RANK_MAX=3   # high แท่ง longest ต้องอยู่อันดับ 1..N ในรอบ lookback
# CANDLE_REVERSAL_1H_LONGEST_RED_EMA_ABOVE_MAX_PCT=13  # ปิดเหนือ EMA ได้ไม่เกิน X% (ดีฟอลต์ 13 — IRYS-class ~12%)
# CANDLE_REVERSAL_1H_LONGEST_RED_EMA_BELOW_MAX_PCT=3   # ปิดใต้ EMA ได้ไม่เกิน X% (เพิ่งหลุด — กัน short ก้นเหว)
# CANDLE_REVERSAL_1H_MARUBOZU_AFTER_DOJI_HOURS=12
# สรุปสแกนหลังแท่งปิด → topic reversal (แบบ Snowball 4h scan summary)
# CANDLE_REVERSAL_SCAN_SUMMARY_TO_CHAT=1
# CANDLE_REVERSAL_SCAN_SUMMARY_MAX_SYMBOLS=45
# CANDLE_REVERSAL_STATS_ENABLED=1
# CANDLE_REVERSAL_STATS_MAX_ROWS=300
# CANDLE_REVERSAL_STATS_WIN_MIN_PCT=0.5    # ผลสรุปที่ 7d (short: ราคาลง = +%)
# CANDLE_REVERSAL_STATS_LOSS_MAX_PCT=-0.5
#
# Top alt จาก Binance 24h quoteVolume (ไม่รวม BTC/ETH และคู่ stable ที่กันในโค้ด) — ค่าเริ่ม 10
# INDICATOR_PUBLIC_TOP_ALTS=15
# Cache รายชื่อ alt ต่อรอบ (ms) — ค่าเริ่ม 2 ชม.
# INDICATOR_PUBLIC_SYMBOL_LIST_TTL_MS=7200000
# Cooldown ต่อสัญญาณ (ms) — ถ้าไม่ตั้ง ใช้ INDICATOR_ALERT_COOLDOWN_MS หรือ 4 ชม.
# INDICATOR_PUBLIC_COOLDOWN_MS=14400000
# INDICATOR_PUBLIC_RSI_ENABLED=1
# INDICATOR_PUBLIC_RSI_PERIOD=14
# INDICATOR_PUBLIC_RSI_THRESHOLD=50  # ข้าม 50 ถูกปิดแจ้งเตือนในโค้ด (กันสัญญาณกลางโซน)
# INDICATOR_PUBLIC_RSI_DIRECTION=both
# TF ของ RSI cross + EMA golden/death (15m | 1h | 4h — ค่าเริ่ม 4h ให้สอดคล้อง divergence)
# INDICATOR_PUBLIC_RSI_EMA_TF=4h
# INDICATOR_PUBLIC_EMA_ENABLED=1
# INDICATOR_PUBLIC_EMA_FAST=12
# INDICATOR_PUBLIC_EMA_SLOW=26
# Day1 เขียวติด (MEXC) — คู่ใหม่ใน list ตามเกณฑ์ minDays → Telegram topic technical — ครั้งเดียวต่อวันหลัง 07:00 น. (ไทย) ใน cron /api/cron/price-sync
# THREE_GREEN_DAILY_TECHNICAL_ENABLED=1
# เกณฑ์ขั้นต่ำ 2–5 วัน (default 3) — หน้า /markets/winners เลือกอิสระด้วย query ?days= ; Telegram ใช้ค่านี้เท่านั้น
# THREE_GREEN_DAILY_STREAK_DAYS=3
# THREE_GREEN_DAILY_NOTIFY_MAX=20
# RSI bullish/bearish divergence — 2 Waves + Confirm ส่งกลุ่มเดียวกับ RSI/EMA (ค่าเริ่มเฉพาะ 4h — 1h มักสัญญาณรบกวน)
# Wave1 = anchor (oversold / overbought) · Wave2 = divergence · ยืนยัน = RSI ตัด SMA(RSI) หรือราคาทะลุแท่งก่อน
# INDICATOR_PUBLIC_RSI_DIVERGENCE_ENABLED=1
# INDICATOR_PUBLIC_RSI_DIVERGENCE_TFS=4h
# รวม 1h อีกครั้ง: INDICATOR_PUBLIC_RSI_DIVERGENCE_TFS=1h,4h
# กว้าง fractal ซ้าย/ขวา (ค่าเริ่ม 2 = หน้าต่าง 5 แท่ง)
# INDICATOR_PUBLIC_DIV_PIVOT_WING=2
# ระยะขั้นต่ำระหว่าง Wave1 กับ Wave2 (แท่ง)
# INDICATOR_PUBLIC_DIV_MIN_PIVOT_GAP=4
# ย้อนหลังเพื่อหา peak/valley (40–150)
# INDICATOR_PUBLIC_DIV_LOOKBACK=80
# Wave1 bull: RSI < oversold · bear: RSI > overbought
# INDICATOR_PUBLIC_DIV_OVERSOLD=30
# INDICATOR_PUBLIC_DIV_OVERBOUGHT=70
# SMA บน RSI สำหรับเงื่อนไขตัดเส้น (ยืนยัน)
# INDICATOR_PUBLIC_DIV_RSI_MA_PERIOD=9
# |RSI wave2 − wave1| ขั้นต่ำ (ชัดเจนระหว่างสองยอด)
# INDICATOR_PUBLIC_DIV_WAVE_MIN_RSI_DELTA=3
# ถ้า |ΔRSI| ระหว่างสอง wave ≥ ค่านี้ → Strong Warning (ใช้คนละตัวกับข้างบนได้)
# INDICATOR_PUBLIC_DIV_STRONG_RSI_DELTA=8

# Snowball Triple-Check — TF จาก Binance USDM (Swing HH/LL และ/หรือทะลุ VAH proxy + Volume + Stoch RSI)
# INDICATOR_PUBLIC_SNOWBALL_ENABLED=1
# TF ของ Snowball: 15m | 1h | 4h (ดีฟอลต์ 4h) — สถิติ follow-up ยังใช้แท่ง 15m เป็นความละเอียด
# INDICATOR_PUBLIC_SNOWBALL_TF=4h
# หลังสแกน Snowball แท่ง 4h ปิด — ส่งสรุปจำนวนสัญญา / ผ่านเกณฑ์ / error ไป Telegram (topic Snowball); ปิด =0
# INDICATOR_PUBLIC_SNOWBALL_4H_SCAN_SUMMARY_TO_CHAT=1
# จำกัดจำนวนชื่อสัญญาในรายการของสรุปสแกน + ผล confirm แท่ง 2 (ดีฟอลต์ 45; สูงสุดในโค้ด 120) — กันข้อความยาวเกิน Telegram
# INDICATOR_PUBLIC_SNOWBALL_SCAN_SUMMARY_MAX_SYMBOLS=45
# จำนวน alt จาก quote volume ที่สแกน Snowball (แยกจาก INDICATOR_PUBLIC_TOP_ALTS) — ดึง universe = max(สองค่า); RSI/EMA/Div ยังจำกัดที่ TOP_ALTS
# INDICATOR_PUBLIC_SNOWBALL_TOP_ALTS=100
# Double Barrier — Barrier2 = แนวใกล้ในโซน % (บรรทัด checklist; คนละความหมายกับ Grade LONG A+/B/C จาก Swing HH + VAH ในหัวข้อ Telegram)
# INDICATOR_PUBLIC_SNOWBALL_DOUBLE_BARRIER_ENABLED=1
# INDICATOR_PUBLIC_SNOWBALL_DOUBLE_BARRIER_LOOKBACK=200
# INDICATOR_PUBLIC_SNOWBALL_DOUBLE_BARRIER_WATCH_MIN_PCT=0.05
# INDICATOR_PUBLIC_SNOWBALL_DOUBLE_BARRIER_WATCH_MAX_PCT=0.1
# เมื่อ Master = 4h — ข้อความ Long เพิ่มแผน Entry / SL / TP (จุดเข้า EMA20 @15m + แนวต้านจาก Vol proxy)
# INDICATOR_PUBLIC_SNOWBALL_4H_PLAN_EMA20_PULLBACK_BAND_PCT=0.003   # สัดส่วนราคา ±0.3% รอบ EMA20 @15m (สูงสุด ~2%)
# INDICATOR_PUBLIC_SNOWBALL_4H_PLAN_SL_BUFFER_PCT=0.1
# INDICATOR_PUBLIC_SNOWBALL_4H_PLAN_TP_LOOKBACK=96
# INDICATOR_PUBLIC_SNOWBALL_4H_PLAN_MAX_TP=3
# Swing lookback HH/LL — ทริกเกอร์สัญญาณ (ดีฟอลต์ 48 แท่ง; สูงสุดใน env 400)
# INDICATOR_PUBLIC_SNOWBALL_SWING_LOOKBACK=48
# Swing HH โครงสร้างใหญ่ — จัด Grade LONG: ไม่ผ่าน HH200 → เกรด C (ดีฟอลต์ 200)
# INDICATOR_PUBLIC_SNOWBALL_SWING_GRADE_LOOKBACK=200
# ไม่นับ high/low ของแท่งล่าสุด N แท่งก่อนแท่งสัญญาณเมื่อหา swing (กันยอด impulse เดียวกันเป็นเพดาน HH / พื้น LL) — ดีฟอลต์ 2
# INDICATOR_PUBLIC_SNOWBALL_SWING_EXCLUDE_RECENT_BARS=2
# Intrabar (แจ้งก่อนปิดแท่งตาม TF Snowball) — ดีฟอลต์ปิด; เปิดด้วย =1 ถ้าต้องการ Sniper
# INDICATOR_PUBLIC_SNOWBALL_INTRABAR=0
# INDICATOR_PUBLIC_SNOWBALL_INTRABAR_RELAX_VOLUME=0
# กรองแท่งไส้ยาว (เฉพาะแท่งปิด): เนื้อเทียน |open−close| ต้อง ≥ ratio × (high−low) จึงจะแจ้งเตือน Snowball — ดีฟอลต์เปิด 70%
# INDICATOR_PUBLIC_SNOWBALL_BODY_TO_RANGE_FILTER_ENABLED=1
# INDICATOR_PUBLIC_SNOWBALL_MIN_BODY_TO_RANGE=0.7
# ถ้าแท่งสัญญาณไม่ผ่าน body÷range แต่แท่งนี้ปิดทะลุ high แท่งก่อน (LONG) / ต่ำกว่า low แท่งก่อน (SHORT) ให้ผ่านกรองไส้ยาว — ดีฟอลต์เปิด
# INDICATOR_PUBLIC_SNOWBALL_BODY_FOLLOW_THROUGH_ENABLED=1
# LONG: เพิ่มทางทะลุ Value Area High แบบ proxy (High ของแท่ง Vol หาในช่วงสั้น) — มักไวกว่าเบรคยอด swing เก่า
# INDICATOR_PUBLIC_SNOWBALL_LONG_VAH_BREAK=1
# INDICATOR_PUBLIC_SNOWBALL_LONG_VAH_LOOKBACK=20
# INDICATOR_PUBLIC_SNOWBALL_VOL_SMA=20
# Vol ต้องมากกว่า SMA * multiplier (default 2.5x) — “แรงกระแทก” จริง
# INDICATOR_PUBLIC_SNOWBALL_VOL_MULT=2.5
# INDICATOR_PUBLIC_SNOWBALL_STOCH_RSI_PERIOD=14
# INDICATOR_PUBLIC_SNOWBALL_STOCH_LENGTH=14
# INDICATOR_PUBLIC_SNOWBALL_STOCH_K_SMOOTH=1   # 1 = ไม่ smooth บน %K; 3 ใกล้เคียง TradingView
# Long: ไม่กรองจาก Stoch RSI เพดานบนแล้ว (ค่าเก่า INDICATOR_PUBLIC_SNOWBALL_STOCH_OVERBOUGHT_MAX ไม่ใช้)
# INDICATOR_PUBLIC_SNOWBALL_STOCH_OVERSOLD_MIN=10     # LL: Stoch RSI ต้อง > นี้
# LONG: ห้ามแจ้งเมื่อราคายังอยู่ใต้ “ก้อน Vol หา” (HVN proxy) — แจ้งเมื่อโผล่เหนือขอบบนก้อนแล้ว (proxy โซนโปร่ง/รูด้านบน; ไม่ใช่ Session VP จริง)
# INDICATOR_PUBLIC_SNOWBALL_LONG_REQUIRE_ABOVE_INNER_HVN=1
# LONG: EMA ต้องมีความชันขึ้น (ค่าแท่งสัญญาณ > แท่งก่อน) — ยืนยันโมเมนตัม
# INDICATOR_PUBLIC_SNOWBALL_LONG_EMA_SLOPE_ENABLED=1
# INDICATOR_PUBLIC_SNOWBALL_LONG_EMA_SLOPE_PERIOD=20
# LONG: ต้องเชิดหัวต่อเนื่อง N แท่ง (default 2 = eNow>ePrev และ ePrev>ePrev2)
# INDICATOR_PUBLIC_SNOWBALL_LONG_EMA_SLOPE_MIN_UP_BARS=2
# LONG: Trend alignment เพิ่ม EMA2 เชิดหัวด้วย (default เปิด; แนะนำ 50)
# INDICATOR_PUBLIC_SNOWBALL_LONG_EMA2_SLOPE_ENABLED=1
# INDICATOR_PUBLIC_SNOWBALL_LONG_EMA2_SLOPE_PERIOD=50
# EMA สำหรับข้อความแนวต้าน playbook SHORT (Sell the Rally)
# INDICATOR_PUBLIC_SNOWBALL_RESISTANCE_EMA=20
# โปร SHORT: proxy “หลุดก้อน SVP/Vol หา” = ปิดใต้ Low ของแท่งที่มี Vol สูงสุดในช่วงด้านใน
# INDICATOR_PUBLIC_SNOWBALL_SVP_HD_INNER_LOOKBACK=24
# INDICATOR_PUBLIC_SNOWBALL_SHORT_REQUIRE_SVP_HD=0   # =1 เพื่อให้แจ้ง SHORT เฉพาะเมื่อหลุด HVN proxy ด้วย

# Snowball Confirming Bar — แท่ง 1 ถ้ามีความเสี่ยง (ไส้ยาวย้อนหลัง / ใกล้โซน Supply / ไส้บนยาวบนแท่งสัญญาณ) ติด label "Pending Confirm" ในข้อความเดิม
# จากนั้นรอแท่งที่ 2 ปิด: ถ้า bar2.close > bar1.high (LONG) หรือ < bar1.low (BEAR) และ volume bar2 ≥ % ของ bar1 → ส่ง "Confirmed" follow-up
# ระบบไม่บล็อกสัญญาณแม้ติด flag ทั้งหมด (3 gates เป็น label เท่านั้น) และไม่ส่ง fail-message เพื่อไม่ spam
# เมื่อมี Pending Confirm: ค่าเริ่มต้นไม่ส่ง Snowball ไปกลุ่ม Telegram จนกว่าแท่ง 2 จะ ✅ Confirmed (Snowball auto-open Super A+ จะรันหลัง Confirm)
# INDICATOR_PUBLIC_SNOWBALL_SKIP_TG_ON_PENDING_CONFIRM=0     # ส่งข้อความแท่ง 1 แบบเดิมพร้อมบล็อก Pending + auto-open ที่แท่งแรก (สถิติ Mini App ยัง append ที่แท่ง 1)
# INDICATOR_PUBLIC_SNOWBALL_CONFIRM_BAR_ENABLED=1
# INDICATOR_PUBLIC_SNOWBALL_WICK_HISTORY_LOOKBACK=50         # ย้อนกี่แท่งก่อนแท่งสัญญาณเพื่อวัดประวัติไส้
# INDICATOR_PUBLIC_SNOWBALL_WICK_HISTORY_RATIO=0.30          # ≥ 30% ของแท่งย้อนหลังมีไส้ยาวกว่าตัว → flag wick_history
# INDICATOR_PUBLIC_SNOWBALL_WICK_BODY_RATIO=1.0              # shadow > body * ratio = แท่งไส้ยาว
# INDICATOR_PUBLIC_SNOWBALL_SIGNAL_WICK_RATIO=1.0            # ไส้บน (LONG) หรือไส้ล่าง (BEAR) บนแท่งสัญญาณเองยาว > body * ratio → flag signal_wick
# INDICATOR_PUBLIC_SNOWBALL_SUPPLY_ZONE_LOOKBACK=200         # หา peak/floor ใน N แท่งก่อนหน้า
# INDICATOR_PUBLIC_SNOWBALL_SUPPLY_ZONE_PCT=0.03             # close อยู่ภายใน 3% ใต้ peak (LONG) / เหนือ floor (BEAR) → flag supply_zone
# INDICATOR_PUBLIC_SNOWBALL_CONFIRM_VOL_MIN_RATIO=0.6        # vol แท่ง 2 ต้อง ≥ 60% ของแท่ง 1 ถึงนับเป็น Confirmed
# INDICATOR_PUBLIC_SNOWBALL_CONFIRM_MAX_AGE_HOURS=12         # pending เกินเวลานี้ → drop เงียบ ๆ กัน state บวม (3 แท่ง 4h)

# Snowball two-bar inline — แท่งสัญญาณ = แท่งปิดก่อนล่าสุด (iClosed−1), confirm = แท่งปิดล่าสุด (iClosed) ในครั้งเดียว
# ค่าเริ่ม **เปิด** (ไม่ตั้ง env = ใช้โหมดนี้): ข้าม body/follow-through บนแท่งสัญญาณ, pullback ≤% ของช่วงสัญญาณ, vol confirm, 1h min-low (LONG) / max-high (BEAR), ส่ง TG ครั้งเดียว, dedupe ใช้เวลเปิดแท่ง confirm
# ตั้งเป็น 0/false เพื่อโหมด legacy: แท่งเดียว (ปิดล่าสุด) + pending confirm + snowballConfirmTick
# INDICATOR_PUBLIC_SNOWBALL_TWO_BAR_INLINE_ENABLED=0
# INDICATOR_PUBLIC_SNOWBALL_TWO_BAR_INLINE_MAX_PULLBACK_OF_RANGE=0.3   # 0–1; LONG: confirmClose ≥ signalClose − ratio×(signalHigh−signalLow); BEAR สมมาตรด้านบน

# Snowball Wave Gate — กันยิงซ้ำในคลื่นเดิม
# ถ้า LONG ยิงไปแล้วและราคายังสูงกว่า lastAlertPrice → ห้ามยิงซ้ำ จนกว่าจะเข้าเงื่อนไขรอบใหม่อย่างน้อย 1:
#   ก) low แตะ EMA${N} แล้วเด้ง (default EMA50) — ถือเป็น pullback รอบใหม่
#   ข) RSI ${TF} หลุดต่ำกว่า threshold (default 50) — wave ก่อนหน้าจบแล้ว
#   ค) close ทะลุ lastAlertPrice * (1 + pct) (default +20%) — คลื่นใหญ่ถัดไป
# BEAR เป็น mirror (close < last, ราคาสูงเกินเกณฑ์/RSI ขึ้นเหนือ 50/แตะ EMA จากด้านล่าง)
# INDICATOR_PUBLIC_SNOWBALL_WAVE_GATE_ENABLED=1
# INDICATOR_PUBLIC_SNOWBALL_WAVE_RSI_RESET_THRESHOLD=50      # 30-70; LONG=หลุดเกณฑ์, BEAR=ขึ้นเกินเกณฑ์
# INDICATOR_PUBLIC_SNOWBALL_WAVE_RSI_PERIOD=14
# INDICATOR_PUBLIC_SNOWBALL_WAVE_EMA_RESET_PERIOD=50         # EMA period สำหรับ pullback touch
# INDICATOR_PUBLIC_SNOWBALL_WAVE_NEW_HIGH_PCT=0.2            # 0.05-1.0 ระยะ breakout ที่ถือว่าเป็น Wave ใหม่ (20% ตามคำขอเริ่มต้น)

# Snowball stats — บันทึกเมื่อส่ง Telegram สำเร็จ + อัปเดต 4h/12h/24h / MFE / DD / RR ในรอบ cron เดียวกับ indicator tick · หน้า /snowball-stats (Mini App)
# SNOWBALL_STATS_ENABLED=1
# SNOWBALL_STATS_MAX_ROWS=400
# Lookback สำหรับ ATR(100) + Max Upper Wick + Range/Wick score ตอนบันทึกสถิติ (ดีฟอลต์ 100 แท่ง)
# Range score = (H−L) แท่งสัญญาณ / ATR(100) · Wick score = UpperWick / MaxWick(100 แท่งก่อนสัญญาณ)
# R% 2 แท่ง = (H−L)/Close×100 แท่งก่อนสัญญาณ + แท่งสัญญาณ (เก็บในสถิติ — ใช้คำนวณ leverage)
# SNOWBALL_STATS_VOLATILITY_LOOKBACK=100
# บริบทตลาดตอนแจ้ง stats: BTC PSAR 4h (Binance) + quoteVolume 24h ของคู่สัญญาณ
# SNOWBALL_STATS_BTC_PSAR_4H_BARS=60
# ถ้า Vol แท่งสัญญาณ / SMA(vol) < ค่านี้ → SVP Hole = Y (proxy โซนวอลุ่มบาง)
# SNOWBALL_STATS_SVP_HOLE_VOL_RATIO_MAX=0.85
# RR: reward จาก pct ปิด 24h หรือ MFE สูงสุด
# SNOWBALL_STATS_RR_REWARD_SOURCE=close_24h   # หรือ mfe
# ผลหลังครบ 24h: pct24 เทียบ entry (ทิศ long/short) ≥ WIN → win_trend · ≤ LOSS → loss
# SNOWBALL_STATS_OUTCOME_WIN_MIN_PCT=0.3
# SNOWBALL_STATS_OUTCOME_LOSS_MAX_PCT=-0.3

# EMA6/12 ตัดกันบน 15m — เฉพาะเหรียญที่กดติดตามใน LIFF (contract watch); รอบเดียวกับ cron /api/cron/price-sync
# EMA612_15M_WATCH_ALERTS_ENABLED=1

# Volume signal (Top 30 vol, TF 1h/4h): Vol spike + momentum score — แจ้ง Telegram/Discord หรือ LINE + cooldown
# VOLUME_SIGNAL_MIN_VOL_RATIO=3
# เฟส 2: |% เปลี่ยนราคาแท่ง| ขั้นต่ำ (0 = ปิด) — ลดสแปมเมื่อ Vol พุ่งแต่ราคาแบน
# VOLUME_SIGNAL_MIN_ABS_RETURN_PCT=0
# เฟส 2: |momentum score| ขั้นต่ำ (0 = ปิด) — score = volRatio × (ΔP/P แท่ง)
# ใช้ร่วม 1h/4h ถ้าไม่ตั้งราย TF
# VOLUME_SIGNAL_MIN_ABS_MOMENTUM=0
# แยกเกณฑ์ตามแท่ง (override ค่าด้านบนเฉพาะ TF นั้น)
# VOLUME_SIGNAL_MIN_ABS_MOMENTUM_1H=
# VOLUME_SIGNAL_MIN_ABS_MOMENTUM_4H=
# VOLUME_SIGNAL_COOLDOWN_MS=14400000

# Upcoming events — high-impact เท่านั้น: US macro (CPI/PPI/PCE · FOMC · NFP) · unlock ≥ % circ. · network/listing (JSON)
# หน้า /upcoming-events · cron /api/cron/upcoming-events ทุก 5 นาที (รวม US session alert) + weekly จันทร์ 00:00 UTC
# FINNHUB_API_KEY=
# TOKEN_UNLOCKS_API_URL=
# TOKEN_UNLOCKS_API_KEY=
# ปลดล็อกเฉพาะเมื่อทราบ % ของ circulating ≥ ค่านี้ (หน่วย % เช่น 1 = 1%) — ถ้า API ไม่ส่ง % จะไม่แสดง ยกเว้นเปิด ALLOW
# UPCOMING_UNLOCK_MIN_PCT_SUPPLY=1
# UPCOMING_UNLOCK_ALLOW_UNKNOWN_PCT=0
# CRYPTO_MARKET_EVENTS_API_URL=
# CRYPTO_MARKET_EVENTS_API_KEY=
# listing เฉพาะ exchange ใหญ่ (Binance/Coinbase/MEXC/…) — ปิด: CRYPTO_LISTING_MAJOR_EXCHANGES_ONLY=0
# CRYPTO_LISTING_MAJOR_EXCHANGES_ONLY=1
# US session BKK ~19:30–20:30 เปิด · ~03:00–04:00 ปิด — ส่งครั้ง/วันเมื่อเข้าช่วง
# ถ้ามี TELEGRAM_PUBLIC_* → ส่งกลุ่ม (events_session topic); ไม่งั้นส่งหาผู้ติดตาม «ติดตามระบบ» (เดียวกับ Market Pulse)
# US_SESSION_ALERTS_ENABLED=1
# UPCOMING_EVENTS_RANGE_DAYS=14
# UPCOMING_EVENTS_CACHE_MAX_AGE_MS=1200000
# UPCOMING_EVENTS_ALERTS_ENABLED=1
# UPCOMING_EVENTS_WEEKLY_ENABLED=1
# UPCOMING_EVENTS_PRE_ALERT_ENABLED=1
# UPCOMING_EVENTS_RESULT_ALERT_ENABLED=1
# เลยเวลาประกาศตามปฏิทินแล้วแต่ Finnhub ยังไม่มี Actual — แจ้งครั้งเดียว (อิงเวลาเดียวกับ pre-event); ต้องเคยส่ง pre-alert แล้ว (ค่าเริ่ม)
# UPCOMING_EVENTS_RESULT_PENDING_ALERT_ENABLED=1
# UPCOMING_EVENTS_RESULT_PENDING_REQUIRES_PRE_ALERT=1
# รอหลังเวลาเหตุการณ์กี่นาทีก่อนส่ง pending (0–120; ค่าเริ่ม 2 — ลดการยิงก่อนเวลาจริงเล็กน้อย)
# UPCOMING_EVENTS_RESULT_PENDING_MINUTES_AFTER=2
# สรุป OpenAI ช่วงถึงเวลา macro (ต้อง OPENAI_API_KEY) — ค่าเริ่มปิด
# UPCOMING_EVENTS_LIVE_AI_ENABLED=1
# UPCOMING_EVENTS_LIVE_AI_WINDOW_MINUTES=15
# เกณฑ์ความสำคัญขั้นต่ำ: high (ค่าเริ่ม) | medium | all
# UPCOMING_EVENTS_LIVE_AI_MIN_IMPORTANCE=high
# Forum topic แยก (ถ้าใช้): TELEGRAM_PUBLIC_EVENTS_LIVE_AI_MESSAGE_THREAD_ID=
# Cron (vercel.json): /api/cron/price-sync ทุก ~15 นาที UTC — แจ้งเตือนเป้าราคา + แจ้งเตือนการเคลื่อนไหวราคา + Volume signal
# และ /api/cron/price-alerts ทุกชั่วโมง UTC — สัญญา / ประวัติ funding
# และ /api/cron/upcoming-events (5 นาที) + /api/cron/upcoming-events-weekly (จันทร์ 00:00 UTC)
# Manual Snowball public scan (ไม่ใช่ใน vercel.json โดยค่าเริ่ม): GET /api/cron/snowball-scan + Bearer CRON_SECRET — หรือ Telegram admin: run cron snowball
# ตั้ง CRON_SECRET ใน Vercel — Vercel Cron จะส่ง Authorization: Bearer <CRON_SECRET>
# ดูบันทึกรอบล่าสุด (JSON): GET /api/cron/status + Authorization: Bearer <CRON_SECRET>
# หรือใน LINE: สถานะ cron / cron status / #cronStatus
# ค่าด้านล่างเป็นตัวยึดที่ — อย่าใช้ใน prod: สร้างลับเอง เช่น openssl rand -hex 32 แล้วใส่ใน Vercel Environment Variables ให้ตรงกับที่ cron ส่ง Bearer
CRON_SECRET=changeme_generate_with_openssl_rand_hex_32

# ทดสอบแจ้งเตือน ผ่าน GET /api/cron/test-push (Bearer CRON_SECRET) — vercel.json รันทุกวันอาทิตย์ 02:00 UTC
# ถ้ามี Telegram/Discord env จะทดสอบช่องนั้น — มิฉะนั้นใช้ LINE_CRON_TEST_USER_ID (LINE push)
# LINE_CRON_TEST_USER_ID=
# ปิดการยิงทดสอบโดยไม่ลบ cron: LINE_CRON_TEST_DISABLED=1

# LINE — เช็คลิสต์เปิด position (short btc / long eth / ชอต btc 5x) + Koji Score
# POSITION_CHECK_FNG_MAX_FOR_SHORT=45
# POSITION_CHECK_NEAR_HIGH_PCT=0.15
# POSITION_CHECK_MIN_VOL_USDT=10000000
# POSITION_CHECK_MIN_MARKET_CAP_USD=50000000
# หักคะแนนเมื่อไม่เข้าเกณฑ์ EMA 15m (checklist)
# POSITION_CHECK_EMA_PRICE_PENALTY=15
# POSITION_CHECK_EMA_ALIGN_PENALTY=10
# Liquidity–Cap ratio = mcap (CoinGecko) / max position USDT (contracts × last) — เกณฑ์แบบ checkLiquidityHealth (SAFE / WATCH / HIGH / TERMINATE)
# POSITION_CHECK_LIQ_CAP_RATIO_WATCH=50000
# POSITION_CHECK_LIQ_CAP_RATIO_HIGH=150000
# POSITION_CHECK_LIQ_CAP_RATIO_EXTREME=500000
# POSITION_CHECK_LIQ_CAP_PENALTY_WATCH=10
# POSITION_CHECK_LIQ_CAP_PENALTY_HIGH=20
# POSITION_CHECK_LIQ_CAP_PENALTY_EXTREME=30
# Spot/Perp volume health: R = perp amount24 ÷ spot quote turnover 24h (USDT, MEXC)
# — BTC/ETH: Tier1 R≤BLUE_SAFE_MAX · Tier2 (BLUE_SAFE_MAX+1)–BLUE_CAUTION_MAX · Tier3 R>BLUE_CAUTION_MAX
# — ZEC,SOL,ADA,NEAR: Tier1 R≤MAJOR_SAFE_MAX · Tier2 ช่วงถัดไปถึง MAJOR_CAUTION_MAX · Tier3 R>MAJOR_CAUTION_MAX
# — เหรียญอื่น: Tier1 R < T2_MIN … Tier4 R ≥ T4_MIN
# POSITION_CHECK_SPOT_FUT_VOL_BLUE_SAFE_MAX=150
# POSITION_CHECK_SPOT_FUT_VOL_BLUE_CAUTION_MAX=300
# POSITION_CHECK_SPOT_FUT_VOL_MAJOR_SAFE_MAX=80
# POSITION_CHECK_SPOT_FUT_VOL_MAJOR_CAUTION_MAX=150
# POSITION_CHECK_SPOT_FUT_VOL_T2_MIN=11
# POSITION_CHECK_SPOT_FUT_VOL_T3_MIN=41
# POSITION_CHECK_SPOT_FUT_VOL_T4_MIN=81
# POSITION_CHECK_SPOT_FUT_VOL_PENALTY_T2=8
# POSITION_CHECK_SPOT_FUT_VOL_PENALTY_T3=18
# POSITION_CHECK_SPOT_FUT_VOL_PENALTY_T4=35
# KOJI_SCORE_LIQ_MIN_VOL_USDT=1000000
# KOJI_SCORE_LIQ_MIN_MCAP_USD=10000000
# KOJI_SCORE_SENT_GREED_THRESHOLD=50
# KOJI_SCORE_BASIS_ABS_PCT=1
# KOJI_SCORE_MAX_LEVERAGE=3

# Dev: เรียก API คนละพอร์ต (ถ้าจำเป็น)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
