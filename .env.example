# LINE Developers Console → Messaging API
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_channel_access_token

# --- แจ้งเตือนอัตโนมัติ (cron) ลำดับ: Telegram → Discord webhook → LINE push (เฉพาะเมื่อเปิดด้านล่าง) ---
# LINE push สำหรับ alert — ค่าเริ่มปิด (เน้น Telegram); ตั้ง =1 เพื่อใช้ LINE เป็นช่องหลักหรือ mirror
# LINE_ALERT_PUSH_ENABLED=1
# Telegram (แนะนำ): สร้างบอทที่ @BotFather แล้วกด Start ที่บอท — ดึง chat_id จาก GET https://api.telegram.org/bot<TOKEN>/getUpdates
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_ALERT_CHAT_ID=123456789
# ส่งซ้ำไป LINE ด้วย: ALERT_ALSO_LINE_PUSH=1 และ LINE_ALERT_PUSH_ENABLED=1
# ALERT_ALSO_LINE_PUSH=1

# Discord (ถ้าไม่ใช้ Telegram): Webhooks — อย่า commit URL จริง; ถ้ารั่วให้ลบ webhook แล้วสร้างใหม่
# DISCORD_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
# DISCORD_ALERT_MENTION_USER_IDS=123456789012345678
# DISCORD_ALERT_ALSO_LINE_PUSH=1

# เว้นระหว่างการเรียก LINE push (มิลลิวินาที) — ใช้เมื่อไม่มี Telegram/Discord (ค่าเริ่ม 280)
# LINE_PUSH_MIN_INTERVAL_MS=280

# LIFF — Channel ID ตัวเลขจาก Basic settings (ใช้ยืนยัน ID token)
LINE_CHANNEL_ID=1234567890
# LIFF ID จากแท็บ LIFF (Endpoint URL = URL Next.js เช่น https://your-app.vercel.app)
LIFF_ID=1234567890-abcdefgh

# optional (local file เมื่อไม่มี REDIS_URL / KV)
# โฟลเดอร์ data/: alerts.json, pct_step_alerts.json, volume_signal_alerts.json, indicator_alerts.json, contract_watches.json, contract_snap_*.json, funding_history_24h.json, system_change_subscribers.json, cron_status.json (legacy), cron_status_hourly.json, cron_status_price_sync.json
PORT=3000

# ราคาและแจ้งเตือนใช้ MEXC Futures (สัญญา *_USDT)
# ถ้าเคยใช้เวอร์ชัน CoinGecko: ลบ data/alerts.json แล้วตั้งเตือนใหม่

# --- Vercel / Next.js เท่านั้น (ไม่มี Express) ---
# Cron (vercel.json): /api/cron/pct-trailing ทุก ~5 นาที (เตือน% trailing) · /api/cron/price-sync ทุก ~15 นาที · /api/cron/price-alerts ทุกชั่วโมง — ส่ง Authorization: Bearer CRON_SECRET
# Webhook: https://<vercel-domain>/webhook
# LIFF เรียก same-origin /api/liff/... — เว้น NEXT_PUBLIC_API_BASE_URL ว่างบน Vercel

# บน Vercel ต้องมีอย่างใดอย่างหนึ่ง: Redis (REDIS_URL) หรือ Vercel KV (KV_REST_API_URL)
# ถ้ามี REDIS_URL จะใช้ node-redis ก่อน (TCP เช่น rediss://default:xxx@xxx.upstash.io:6379)
# ถ้าไม่มี Redis แต่มี KV_REST_API_URL ระบบจะใช้ @vercel/kv เหมือนเดิม
# REDIS_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# หน้า /markets แสดงคอลัมน์ Score·Vol×·15m ตลอด (ไม่ต้องใส่ ?debug=1)
# MARKETS_DEBUG_COLUMNS=1

# เกณฑ์แจ้งเตือน funding: |Δrate|×100 ≥ ค่านี้ (หน่วย % pt เช่น 0.1 = 0.01% → 0.11% ถึงแจ้ง) — ค่าเริ่มในโค้ด 0.1
# System conditions (LINE): แจ้งเมื่อ funding rate ถึงเกณฑ์นี้ หรือรอบชำระ (ชม.) เปลี่ยน หรือ max order size เปลี่ยน — ไม่แจ้งเมื่อมีแค่เวลาตัดถัดไป (nextSettleTime) เปลี่ยน
# CONTRACT_FUNDING_MIN_DELTA_DISPLAY=0.1

# Indicator alerts: RSI 14 บน TF 1h/4h + EMA cross 1h/4h — รวมจำนวนต่อ user · ดึง kline แบบ unique (symbol,TF) ต่อรอบ
# INDICATOR_ALERT_MAX_PER_USER=30
# INDICATOR_ALERT_COOLDOWN_MS=14400000

# Volume signal (Top 30 vol, TF 1h/4h): Vol spike + momentum score — แจ้ง Telegram/Discord หรือ LINE + cooldown
# VOLUME_SIGNAL_MIN_VOL_RATIO=3
# เฟส 2: |% เปลี่ยนราคาแท่ง| ขั้นต่ำ (0 = ปิด) — ลดสแปมเมื่อ Vol พุ่งแต่ราคาแบน
# VOLUME_SIGNAL_MIN_ABS_RETURN_PCT=0
# เฟส 2: |momentum score| ขั้นต่ำ (0 = ปิด) — score = volRatio × (ΔP/P แท่ง)
# VOLUME_SIGNAL_MIN_ABS_MOMENTUM=0
# VOLUME_SIGNAL_COOLDOWN_MS=14400000

# Cron (vercel.json): /api/cron/price-sync ทุก ~15 นาที UTC — แจ้งเตือนเป้าราคา + แจ้งเตือนการเคลื่อนไหวราคา + Volume signal
# และ /api/cron/price-alerts ทุกชั่วโมง UTC — สัญญา / ประวัติ funding
# ตั้ง CRON_SECRET ใน Vercel — Vercel Cron จะส่ง Authorization: Bearer <CRON_SECRET>
# ดูบันทึกรอบล่าสุด (JSON): GET /api/cron/status + Authorization: Bearer <CRON_SECRET>
# หรือใน LINE: สถานะ cron / cron status / #cronStatus
# ค่าด้านล่างเป็นตัวยึดที่ — อย่าใช้ใน prod: สร้างลับเอง เช่น openssl rand -hex 32 แล้วใส่ใน Vercel Environment Variables ให้ตรงกับที่ cron ส่ง Bearer
CRON_SECRET=changeme_generate_with_openssl_rand_hex_32

# ทดสอบแจ้งเตือน ผ่าน GET /api/cron/test-push (Bearer CRON_SECRET) — vercel.json รันทุกวันอาทิตย์ 02:00 UTC
# ถ้ามี Telegram/Discord env จะทดสอบช่องนั้น — มิฉะนั้นใช้ LINE_CRON_TEST_USER_ID (LINE push)
# LINE_CRON_TEST_USER_ID=
# ปิดการยิงทดสอบโดยไม่ลบ cron: LINE_CRON_TEST_DISABLED=1

# Dev: เรียก API คนละพอร์ต (ถ้าจำเป็น)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
