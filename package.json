{
  "name": "koji-line-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Koji — LINE OA bot for crypto price alerts and signals",
  "type": "module",
  "scripts": {
    "build": "npm run build:web && npm run build:api",
    "build:api": "tsc -p tsconfig.server.json",
    "build:web": "next build",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "dev:web": "next dev -p 3001",
    "dev:all": "concurrently -n api,web -c blue,magenta \"npm run dev\" \"npm run dev:web\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@line/bot-sdk": "^9.5.0",
    "@line/liff": "^2.24.0",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "next": "14.2.18",
    "node-cron": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
