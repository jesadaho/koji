{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "crons": [
    {
      "path": "/api/cron/pct-trailing",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/price-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/price-alerts",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/test-push",
      "schedule": "0 2 * * 0"
    }
  ]
}
